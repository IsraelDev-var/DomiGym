# ── Base de datos ─────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/domigym_db?sslmode=require

# ── JWT ───────────────────────────────────────────────────
# Genera con: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=<reemplaza-con-secreto-aleatorio-64-bytes>
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=<reemplaza-con-otro-secreto-aleatorio-64-bytes>
JWT_REFRESH_EXPIRES_IN=30d

# ── Servidor ──────────────────────────────────────────────
PORT=3051
NODE_ENV=production

# ── CORS ──────────────────────────────────────────────────
FRONTEND_URL=https://tu-frontend.railway.app
